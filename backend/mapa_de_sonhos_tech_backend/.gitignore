### Python / Django ###
# Ambiente virtual (nunca envie esta pasta, ela é pesada e específica do seu PC)
venv/
ENV/
env/

# Arquivos compilados do Python
__pycache__/
*.py[cod]
*$py.class

# Banco de dados local (SQLite)
# Em produção usaremos PostgreSQL, então o arquivo local não deve ir para o Git
*.sqlite3

# Arquivos de log
*.log

# Pasta de arquivos estáticos coletados (gerada pelo Django em produção)
staticfiles/

### Segurança ###
# Nunca envie arquivos que contenham senhas ou chaves secretas
.env

### Frontend / Web ###
# Pastas de dependências (caso você use npm no futuro)
node_modules/

# Arquivos de sistema operacional
.DS_Store
Thumbs.db

### IDEs ###
# Configurações do VS Code ou PyCharm
.vscode/
.idea/
 